# Env-файл для /docker-compose-dev.yml.
# Скопировать в /.env и заполнить свои значения.
# Compose сам подхватит .env рядом с docker-compose-dev.yml — флаги не нужны.

# ════════════════════════════════════════════════
#  SoundCloud OAuth (backend)
# ════════════════════════════════════════════════
SOUNDCLOUD_CLIENT_ID=your_client_id
SOUNDCLOUD_CLIENT_SECRET=your_client_secret
SOUNDCLOUD_REDIRECT_URI=http://localhost:3000/auth/callback

# ════════════════════════════════════════════════
#  SoundCloud Proxy / Cookies (backend + streaming)
# ════════════════════════════════════════════════
SC_PROXY_URL=
SC_PROXY_FALLBACK=false
# Cookies для streaming (обход 401)
SC_COOKIES=

# ════════════════════════════════════════════════
#  Admin / Internal tokens
# ════════════════════════════════════════════════
# Общий admin-token (backend /admin/*, storage upload/delete, streaming → storage auth)
ADMIN_TOKEN=dev
# Внутренний токен для backend → streaming /internal/* (pipeline)
INTERNAL_TOKEN=dev-internal
# Публичный адрес storage для клиента (например http://localhost:3002 в dev).
# Если пусто — streaming отдаёт internal STORAGE_URL.
STORAGE_PUBLIC_URL=
# Отдельный upload-хост (если write-инстанс отличается от read). Пусто → = STORAGE_URL.
STORAGE_UPLOAD_URL=

# ════════════════════════════════════════════════
#  Storage (выбор backend + S3 при необходимости)
# ════════════════════════════════════════════════
STORAGE_BACKEND=local
MAX_TRANSCODES=2
TRANSCODE_BATCH_SIZE=8
TRANSCODE_BATCH_WAIT_MS=50
UPLOAD_CONCURRENCY=64
UPLOAD_RETRIES=4
UPLOAD_RETRY_BASE_MS=250

# Если STORAGE_BACKEND=s3 — заполнить:
S3_ENDPOINT=
S3_REGION=us-east-1
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_FORCE_PATH_STYLE=true

# ════════════════════════════════════════════════
#  Streaming (storage cache cleanup + premium)
# ════════════════════════════════════════════════
PREMIUM_ONLY=false
STORAGE_CLEANUP_DAYS=7
STORAGE_MAX_SIZE_BYTES=0
STORAGE_CLEANUP_INTERVAL_SECS=3600

# ════════════════════════════════════════════════
#  Worker (Gemma / Whisper)
# ════════════════════════════════════════════════
MINI_MODEL=google/gemma-4-E2B-it
WHISPER_MODEL=base
WHISPER_COMPUTE=int8

# ════════════════════════════════════════════════
#  Genius (artist crawl + lyrics)
# ════════════════════════════════════════════════
# https://genius.com/api-clients → New API Client → Generate Access Token
# Без него API.genius.com отвалится 401, останется только web-scrape (медленнее, чаще падает на 429).
GENIUS_ACCESS_TOKEN=

# ════════════════════════════════════════════════
#  SoundWave RRF fusion (backend recommendations)
# ════════════════════════════════════════════════
# Веса веток RRF (сумма ≈ 1, но не обязательно).
SOUNDWAVE_AUDIO_WEIGHT=0.5    # tracks_mert (MuQ)
SOUNDWAVE_CLAP_WEIGHT=0.25    # tracks_clap (MuQ-MuLan)
SOUNDWAVE_LYRICS_WEIGHT=0.25  # tracks_lyrics (bge-m3)
# Макс. треков одного артиста в выдаче (после RRF).
SOUNDWAVE_ARTIST_CAP=2
# log1p(playback_count) × boost добавляется к score.
SOUNDWAVE_POPULARITY_BOOST=0.01
# Нижний порог cos-similarity в qdrant.recommend (0.3 мягкий, 0.5 жёсткий).
SOUNDWAVE_SCORE_THRESHOLD=0.3
