# ─── Core ───
PORT=8080

# ─── Database (PostgreSQL, только чтение для stream tracking) ───
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USERNAME=soundcloud
DATABASE_PASSWORD=soundcloud
DATABASE_NAME=soundcloud_desktop

# ─── SoundCloud Proxy (опционально) ───
SC_PROXY_URL=
SC_PROXY_FALLBACK=false
# Cookies для обхода 401 на некоторых треках
SC_COOKIES=

# ─── Premium-only режим ───
PREMIUM_ONLY=false

# ─── Storage ───
# STORAGE_URL        — адрес storage для streaming'а (head/serve/delete, внутри сети)
# STORAGE_PUBLIC_URL — адрес, отдаваемый клиенту для редиректа; пусто → = STORAGE_URL
# STORAGE_UPLOAD_URL — отдельный адрес для upload (write-инстанс); пусто → = STORAGE_URL
# STORAGE_TOKEN      — Bearer token (= ADMIN_TOKEN у storage)
STORAGE_URL=
STORAGE_PUBLIC_URL=
STORAGE_UPLOAD_URL=
STORAGE_TOKEN=
STORAGE_CLEANUP_DAYS=7
STORAGE_MAX_SIZE_BYTES=0
STORAGE_CLEANUP_INTERVAL_SECS=3600

# ─── Internal pipeline (backend → streaming /internal/*) ───
INTERNAL_TOKEN=dev-internal

# ─── TLS / Let's Encrypt (опционально) ───
# Если TLS_ENABLED=true — сервис сам слушает :443 (HTTPS) и :80 (HTTP-редирект),
# выпускает и авто-перевыпускает серты через ACME tls-alpn-01. PORT игнорируется.
# При TLS_ENABLED=false (default) — старое поведение на 0.0.0.0:PORT.
TLS_ENABLED=false
# Comma-separated список доменов, на которые выпускать серт. Обязателен при TLS_ENABLED=true.
DOMAINS=
# Контактный email для Let's Encrypt. По умолчанию admin@<первый-домен>.
ACME_EMAIL=
# Куда класть серты и приват-ключ. ДОЛЖЕН быть persistent volume —
# иначе при рестарте контейнера LE задаст rate-limit.
ACME_CACHE_DIR=/var/cache/acme
# true = staging LE (для тестов, невалидный серт). false = prod.
ACME_STAGING=false
# Порты. Дефолты (443/80) обычно менять не нужно.
TLS_HTTPS_PORT=443
TLS_HTTP_PORT=80
# 301 HTTP→HTTPS. Выключай только если нужен mixed-mode.
TLS_HTTP_REDIRECT=true
