# Переменные для worker/docker-compose.yml (standalone-запуск воркера).
# Для общего запуска используй /docker-compose-dev.yml и /.env в корне.

# ─── NATS ───
# В проде креды в URL: nats://user:pass@host:4222
# Единственный внешний API воркера — вектора пишет в Qdrant backend, не воркер.
NATS_URL=nats://localhost:4222

# ─── Worker replicas ───
WORKER_REPLICAS=2

# ─── Task lifecycle ───
# Хартбит "я работаю ещё" — каждые N сек обновляет ack_wait в JetStream
TASK_HEARTBEAT_SEC=10
# Жёсткий таймаут задачи — после него воркер бросает, сообщение идёт другому консьюмеру
TASK_HARD_TIMEOUT_SEC=120
# Транскрайб (demucs+whisper) идёт минуты, а не секунды — свой увеличенный лимит
TRANSCRIBE_HARD_TIMEOUT_SEC=1800

# ─── Параллелизм по типам задач ───
# ""/"1"  → один общий Semaphore(1) на все теги (GPU-friendly дефолт)
# "N"     → общий Semaphore(N)
# "ai=2,transcribe=1,audio=1,lyrics=2,collab=1,quality=1" → свой семафор на тег.
#   Рекомендация для GPU-бокса с интерактивом: вынести transcribe в отдельную
#   дорожку, чтобы 30-мин whisper не блокировал user-facing ai.rpc.*.
#   "transcribe=0" — полностью отключить self-gen на этом воркере.
WORKER_CONCURRENCY=

# ─── Mini LLM (лирика-поиск через transformers) ───
MINI_MODEL=Qwen/Qwen2.5-0.5B-Instruct

# ─── Whisper (self-gen synced LRC) ───
WHISPER_MODEL=base
WHISPER_COMPUTE=int8