# ─── Core ───
PORT=3000

# ─── Admin (required) ───
# Bearer token для upload/delete endpoints
ADMIN_TOKEN=change_me

# ─── Backend: local | s3 ───
STORAGE_BACKEND=local

# ─── Local backend ───
STORAGE_PATH=/data/storage
# Корень рабочего tmp. Внутри сервис автоматически создаёт source/ (raw uploads)
# и result/ (выходы ffmpeg, ждут отправки в backend).
TMP_PATH=/tmp/storage

# ─── Transcoding ───
FFMPEG_BIN=ffmpeg
FFPROBE_BIN=ffprobe
# Макс. одновременных ffmpeg-процессов (каждый процесс жуёт целый батч).
MAX_TRANSCODES=2
# Сколько треков склеиваем в один ffmpeg-вызов (multi-input → multi-output).
TRANSCODE_BATCH_SIZE=8
# Сколько мс ждём добор батча, прежде чем стрелять ffmpeg-ом.
TRANSCODE_BATCH_WAIT_MS=50
# Макс. длительность трека (сек). Длиннее — не транскодятся и отклоняются на
# /upload (по аналогии с backend MAX_TRACK_DURATION_SEC). 0 = без лимита.
MAX_TRACK_DURATION_SEC=420
# Лимит общего размера source/-каталога в ГБ. 0/пусто = без лимита.
TMP_MAX_GB=0
# Если true — /upload отдаёт 503. Для хостов-раздатчиков без ffmpeg.
DISABLE_UPLOAD=false

# ─── Backend uploads (S3 / local rename) ───
# Параллельные backend-загрузки. На S3-хайлоаде разумно 32-128.
UPLOAD_CONCURRENCY=64
# Сколько раз ретраить одну загрузку.
UPLOAD_RETRIES=4
# База exponential backoff между ретраями (мс).
UPLOAD_RETRY_BASE_MS=250

# ─── S3 backend (если STORAGE_BACKEND=s3) ───
S3_ENDPOINT=
S3_REGION=us-east-1
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_FORCE_PATH_STYLE=true

# ─── NATS (опционально) ───
# JetStream URL. Storage публикует `storage.track_uploaded` после реального
# завершения upload (включая retry). Пусто = no-op publisher.
NATS_URL=
# Публичный базовый URL storage — попадает в payload события как
# `{event_base_url}/redirect/hq/{filename}.ogg` (worker идёт по нему).
# Должен совпадать с STORAGE_PUBLIC_URL в стриминге/бэке.
EVENT_BASE_URL=

# ─── TLS / Let's Encrypt (опционально) ───
# Если TLS_ENABLED=true — сервис сам слушает :443 (HTTPS) и :80 (HTTP-редирект),
# выпускает и авто-перевыпускает серты через ACME tls-alpn-01. PORT игнорируется.
# При TLS_ENABLED=false (default) — старое поведение на 0.0.0.0:PORT.
TLS_ENABLED=false
# Comma-separated список доменов, на которые выпускать серт. Обязателен при TLS_ENABLED=true.
DOMAINS=
# Контактный email для Let's Encrypt. По умолчанию admin@<первый-домен>.
ACME_EMAIL=
# Куда класть серты и приват-ключ. ДОЛЖЕН быть persistent volume —
# иначе при рестарте контейнера LE задаст rate-limit.
ACME_CACHE_DIR=/var/cache/acme
# true = staging LE (для тестов, невалидный серт). false = prod.
ACME_STAGING=false
# Порты. Дефолты (443/80) обычно менять не нужно.
TLS_HTTPS_PORT=443
TLS_HTTP_PORT=80
# 301 HTTP→HTTPS. Выключай только если нужен mixed-mode.
TLS_HTTP_REDIRECT=true
