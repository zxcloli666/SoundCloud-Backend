# Copy to .env and fill in credentials.
# Usage: set -a; source .env; set +a

# Required
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Optional
# Leave empty for AWS; set for S3-compatible providers:
#   MinIO:        http://localhost:9000
#   Cloud.ru:     https://storage.clo.ru
#   Yandex:       https://storage.yandexcloud.net
#   DigitalOcean: https://nyc3.digitaloceanspaces.com
# S3_ENDPOINT=

# S3_REGION=us-east-1

# Prefix applied to all per-user buckets: bucket = <prefix><slug>
# S3_BUCKET_PREFIX=user-

# Optional public URL template; {bucket} is substituted.
# Examples:
#   https://{bucket}.storage.clo.ru
#   https://{bucket}.cdn.example.com
# S3_PUBLIC_URL_TEMPLATE=
